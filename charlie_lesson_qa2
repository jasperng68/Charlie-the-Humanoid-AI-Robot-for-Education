from openai import OpenAI
import asyncio
import websockets
import json
import base64
import pyaudio
import os
import subprocess
import time
import threading
import random
import numpy as np
from scipy.signal import resample_poly

from motion_engine1 import play_sequence, wave_left, go_home, shutdown_motors

API_KEY = os.getenv("OPENAI_API_KEY")
client = OpenAI(timeout=60.0)

URL = "wss://api.openai.com/v1/realtime?model=gpt-realtime-mini"

CHUNK = 1024
FORMAT = pyaudio.paInt16

INPUT_RATE = 16000
OUTPUT_RATE = 24000
CHANNELS = 1

INPUT_DEVICE_INDEX = 1
OUTPUT_DEVICE_INDEX = 6

VOICE = "echo"
AUDIO_DEVICE = "pulse"

robot_awake = True

GESTURES = (
    ["thinking", "listening"] +
    [f"right_gesture{i}" for i in range(1, 13)] +
    [f"left_gesture{i}" for i in range(1, 13)] +
    ["both_open", "both_open_wide", "both_up_small"]
)

qa_gesture_stop = None
qa_gesture_thread = None


def set_face_state(state):
    with open("face_state.txt", "w") as f:
        f.write(state)


def gesture_loop(stop_event, min_wait=0.15, max_wait=0.45):
    """
    Continuous autonomous gestures.
    It does NOT go home after every gesture.
    It moves from one gesture directly to another.
    Home is called once when speech/answer finishes.
    """
    while not stop_event.is_set():
        gesture = random.choice(GESTURES)
        print("Gesture:", gesture)

        play_sequence([
            (gesture, random.uniform(0.45, 0.75))
        ], speed=120, release=False)

        time.sleep(random.uniform(min_wait, max_wait))


def start_qa_gestures():
    global qa_gesture_stop, qa_gesture_thread

    if qa_gesture_thread and qa_gesture_thread.is_alive():
        return

    qa_gesture_stop = threading.Event()

    qa_gesture_thread = threading.Thread(
        target=gesture_loop,
        args=(qa_gesture_stop,),
        daemon=True
    )

    qa_gesture_thread.start()


def stop_qa_gestures():
    global qa_gesture_stop, qa_gesture_thread

    if qa_gesture_stop:
        qa_gesture_stop.set()

    if qa_gesture_thread and qa_gesture_thread.is_alive():
        qa_gesture_thread.join()

    qa_gesture_stop = None
    qa_gesture_thread = None

    go_home()


def robot_say(text, gesture=True):
    print("Charlie:", text)

    speech = client.audio.speech.create(
        model="gpt-4o-mini-tts",
        voice=VOICE,
        input=text,
        response_format="wav"
    )

    speech.write_to_file("lesson_reply.wav")

    stop_event = threading.Event()
    gesture_thread = None

    if gesture:
        gesture_thread = threading.Thread(
            target=gesture_loop,
            args=(stop_event,),
            daemon=True
        )
        gesture_thread.start()

    set_face_state("talking")

    player = subprocess.Popen([
        "aplay",
        "-D",
        AUDIO_DEVICE,
        "lesson_reply.wav"
    ])

    player.wait()
    set_face_state("idle")

    if gesture:
        stop_event.set()
        gesture_thread.join()

    go_home()


def say_with_motion(text, motion=None):
    motion_thread = None

    if motion:
        motion_thread = threading.Thread(target=motion)
        motion_thread.start()

    robot_say(text, gesture=False)

    if motion_thread:
        motion_thread.join()

    go_home()


