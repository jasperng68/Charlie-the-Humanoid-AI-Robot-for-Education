async def send_audio(ws, stream_in):
    while True:
        audio = stream_in.read(CHUNK, exception_on_overflow=False)
        samples = np.frombuffer(audio, dtype=np.int16)
        samples_24k = resample_poly(samples, 3, 2).astype(np.int16)

        encoded = base64.b64encode(samples_24k.tobytes()).decode("utf-8")

        await ws.send(json.dumps({
            "type": "input_audio_buffer.append",
            "audio": encoded
        }))

        await asyncio.sleep(0.01)


async def receive_audio(ws, stream_out):
    global robot_awake

    while True:
        message = await ws.recv()
        data = json.loads(message)
        event_type = data.get("type")

        if event_type in ["response.output_audio.delta", "response.audio.delta"]:
            if robot_awake:
                start_qa_gestures()
                set_face_state("talking")

                audio_chunk = base64.b64decode(data["delta"])
                stream_out.write(audio_chunk)

        elif event_type in ["response.output_audio.done", "response.audio.done", "response.done"]:
            set_face_state("idle")
            threading.Thread(target=stop_qa_gestures, daemon=True).start()

        elif event_type == "input_audio_buffer.speech_started":
            print("ð¤ I hear you...")
            threading.Thread(target=go_home, daemon=True).start()

        elif event_type == "input_audio_buffer.speech_stopped":
            print("ð§  Thinking...")
            threading.Thread(
                target=lambda: play_sequence([("thinking", 0.8)], speed=120, release=False),
                daemon=True
            ).start()

        elif event_type == "error":
            print("â Error:", data)


async def realtime_qa():
    p = pyaudio.PyAudio()

    stream_in = p.open(
        format=FORMAT,
        channels=CHANNELS,
        rate=INPUT_RATE,
        input=True,
        input_device_index=INPUT_DEVICE_INDEX,
        frames_per_buffer=CHUNK,
    )

    stream_out = p.open(
        format=FORMAT,
        channels=CHANNELS,
        rate=OUTPUT_RATE,
        output=True,
        output_device_index=OUTPUT_DEVICE_INDEX,
        frames_per_buffer=CHUNK,
    )

    try:
        async with websockets.connect(
            URL,
            additional_headers={
                "Authorization": f"Bearer {API_KEY}"
            }
        ) as ws:

            await ws.send(json.dumps({
                "type": "session.update",
                "session": {
                    "type": "realtime",
                    "instructions": "You are Charlie, an energetic, playful, cheerful robot teacher. Answer student questions about cell structure clearly and briefly.",
                    "output_modalities": ["audio"],
                    "audio": {
                        "input": {
                            "format": {
                                "type": "audio/pcm",
                                "rate": 24000
                            },
                            "turn_detection": {
                                "type": "server_vad",
                                "threshold": 0.75,
                                "prefix_padding_ms": 500,
                                "silence_duration_ms": 1000
                            },
                            "transcription": {
                                "model": "gpt-4o-mini-transcribe"
                            }
                        },
                        "output": {
                            "format": {
                                "type": "audio/pcm",
                                "rate": 24000
                            },
                            "voice": "echo"
                        }
                    }
                }
            }))

            print("ð¤ Q&A started. Ask Charlie your questions.")

            await asyncio.gather(
                send_audio(ws, stream_in),
                receive_audio(ws, stream_out)
            )

    finally:
        set_face_state("idle")
        try:
            stop_qa_gestures()
        except Exception:
            pass

        stream_in.stop_stream()
        stream_in.close()
        stream_out.stop_stream()
        stream_out.close()
        p.terminate()


try:
    set_face_state("idle")
    face_process = subprocess.Popen(["python3", "face.py"])

    time.sleep(1)

    go_home()

    teach_lesson()

    print("Starting question and answer session...")
    go_home()

    asyncio.run(realtime_qa())

finally:
    set_face_state("idle")
    go_home()
    face_process.terminate()
    shutdown_motors()