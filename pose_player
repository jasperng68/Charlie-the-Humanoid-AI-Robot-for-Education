from dynamixel_sdk import *
import json
import time
import sys

DEVICENAME = "/dev/ttyUSB0"
BAUDRATE = 1000000
PROTOCOL_VERSION = 1.0

ADDR_TORQUE_ENABLE = 24
ADDR_GOAL_POSITION = 30
ADDR_MOVING_SPEED = 32

TORQUE_ENABLE = 1
TORQUE_DISABLE = 0

POSE_FILE = "charlie_poses.json"

portHandler = PortHandler(DEVICENAME)
packetHandler = PacketHandler(PROTOCOL_VERSION)

def load_poses():
    with open(POSE_FILE, "r") as f:
        return json.load(f)

def enable_torque(dxl_id):
    packetHandler.write1ByteTxRx(
        portHandler, dxl_id, ADDR_TORQUE_ENABLE, TORQUE_ENABLE
    )

def disable_torque(dxl_id):
    packetHandler.write1ByteTxRx(
        portHandler, dxl_id, ADDR_TORQUE_ENABLE, TORQUE_DISABLE
    )

def move_to(dxl_id, position, speed=80):
    enable_torque(dxl_id)
    packetHandler.write2ByteTxRx(portHandler, dxl_id, ADDR_MOVING_SPEED, speed)
    packetHandler.write2ByteTxRx(portHandler, dxl_id, ADDR_GOAL_POSITION, position)

if len(sys.argv) < 2:
    print("Usage: python3 pose_player.py pose_name")
    print("Example: python3 pose_player.py home")
    quit()

pose_name = sys.argv[1]

poses = load_poses()

if pose_name not in poses:
    print(f"Pose '{pose_name}' not found.")
    print("Available poses:", list(poses.keys()))
    quit()

if not portHandler.openPort():
    print("Failed to open port")
    quit()

if not portHandler.setBaudRate(BAUDRATE):
    print("Failed to set baudrate")
    quit()

pose = poses[pose_name]

print(f"Moving to pose: {pose_name}")

for dxl_id_str, position in pose.items():
    dxl_id = int(dxl_id_str)
    move_to(dxl_id, int(position), speed=80)

time.sleep(2)

for dxl_id_str in pose.keys():
    disable_torque(int(dxl_id_str))

portHandler.closePort()

print("Done.")
